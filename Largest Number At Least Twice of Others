class Solution {
    public int dominantIndex(int[] nums) {
        int max=-1;
        int maxindex=0;
        for(int i=0;i<nums.length;i++){
            if(max<nums[i]){
                max=nums[i];
                maxindex=i;
            }
        }
        for(int i=0;i<nums.length;i++){
            if(i!=maxindex){
               if(max<2*nums[i]) {
                return -1;
               }
               
               }
            }
            return maxindex;
        }
    }
